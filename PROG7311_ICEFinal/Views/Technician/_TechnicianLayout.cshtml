<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PC Society Technician</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <style>
        :root {
            --teal: #4aada8;
            --teal-dark: #3a9490;
            --teal-light: #d4eeec;
            --sidebar-bg: #3a9490;
            --sidebar-width: 210px;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: #f0f4f4;
            margin: 0;
        }

        /* ── Sidebar ── */
        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: var(--sidebar-width);
            height: 100vh;
            background: var(--sidebar-bg);
            display: flex;
            flex-direction: column;
            z-index: 100;
        }

        .sidebar-header {
            padding: 1.2rem 1rem 1rem;
            border-bottom: 1px solid rgba(255,255,255,.2);
        }

            .sidebar-header .menu-label {
                color: #fff;
                font-size: .75rem;
                font-weight: 600;
                letter-spacing: .12em;
                text-transform: uppercase;
                display: flex;
                align-items: center;
                gap: .5rem;
            }

        .sidebar-nav {
            flex: 1;
            padding: .75rem 0;
        }

            .sidebar-nav a {
                display: flex;
                align-items: center;
                gap: .65rem;
                padding: .7rem 1.1rem;
                color: rgba(255,255,255,.85);
                text-decoration: none;
                font-size: .875rem;
                font-weight: 500;
                transition: background .15s, color .15s;
            }

                .sidebar-nav a:hover,
                .sidebar-nav a.active {
                    background: rgba(255,255,255,.15);
                    color: #fff;
                }

                .sidebar-nav a svg {
                    flex-shrink: 0;
                    opacity: .8;
                }

        .sidebar-footer {
            padding: 1rem;
            border-top: 1px solid rgba(255,255,255,.2);
        }

            .sidebar-footer a {
                display: flex;
                align-items: center;
                gap: .5rem;
                color: rgba(255,255,255,.8);
                text-decoration: none;
                font-size: .875rem;
                font-weight: 500;
            }

                .sidebar-footer a:hover {
                    color: #fff;
                }

        /* ── Topbar ── */
        .topbar {
            position: fixed;
            top: 0;
            left: var(--sidebar-width);
            right: 0;
            height: 56px;
            background: var(--teal);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 1.5rem;
            z-index: 99;
        }

            .topbar h1 {
                color: #fff;
                font-size: 1.25rem;
                font-weight: 600;
                margin: 0;
            }

            .topbar .brand {
                color: rgba(255,255,255,.75);
                font-size: .8rem;
                font-weight: 600;
                letter-spacing: .08em;
            }

            .topbar .user-icon {
                width: 34px;
                height: 34px;
                background: rgba(255,255,255,.2);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                color: #fff;
            }

        /* ── Main content ── */
        .main-content {
            margin-left: var(--sidebar-width);
            padding-top: 56px;
            min-height: 100vh;
        }

        .page-body {
            padding: 1.75rem;
        }

        /* ── Common components ── */
        .page-title {
            font-size: 1.4rem;
            font-weight: 600;
            color: #1a2e2e;
            margin-bottom: .25rem;
        }

        .page-subtitle {
            font-size: .875rem;
            color: #6a8080;
            margin-bottom: 1.25rem;
        }

        .pc-card {
            background: #fff;
            border-radius: 10px;
            border: 1px solid #e2eded;
            box-shadow: 0 1px 4px rgba(0,0,0,.06);
        }

        .pc-table {
            width: 100%;
            border-collapse: collapse;
            font-size: .875rem;
        }

            .pc-table thead tr {
                background: #f5fafa;
                border-bottom: 2px solid var(--teal-light);
            }

            .pc-table th {
                padding: .75rem 1rem;
                font-weight: 600;
                color: #4a6060;
                text-align: left;
                white-space: nowrap;
            }

            .pc-table td {
                padding: .7rem 1rem;
                color: #2d4040;
                border-bottom: 1px solid #eef4f4;
            }

            .pc-table tbody tr:hover {
                background: #f8fbfb;
            }

            .pc-table tbody tr:last-child td {
                border-bottom: none;
            }

        /* Status badges */
        .badge-pending {
            background: #fff3cd;
            color: #856404;
            border: 1px solid #ffe08a;
        }

        .badge-inprogress {
            background: #cff4fc;
            color: #055160;
            border: 1px solid #9eeaf9;
        }

        .badge-completed {
            background: #d1e7dd;
            color: #0a3622;
            border: 1px solid #a3cfbb;
        }

        .badge-cancelled {
            background: #f8d7da;
            color: #842029;
            border: 1px solid #f5c2c7;
        }

        .status-badge {
            display: inline-block;
            padding: .25rem .65rem;
            border-radius: 20px;
            font-size: .75rem;
            font-weight: 600;
        }

        /* Filter / search bar */
        .filter-bar {
            display: flex;
            align-items: center;
            gap: .75rem;
            flex-wrap: wrap;
            margin-bottom: 1rem;
        }

            .filter-bar .search-wrap {
                position: relative;
                flex: 1;
                min-width: 180px;
                max-width: 320px;
            }

                .filter-bar .search-wrap svg {
                    position: absolute;
                    left: .65rem;
                    top: 50%;
                    transform: translateY(-50%);
                    color: #888;
                }

            .filter-bar input[type=text] {
                width: 100%;
                padding: .45rem .75rem .45rem 2rem;
                border: 1px solid #ccdede;
                border-radius: 6px;
                font-size: .875rem;
                background: #f8fbfb;
            }

                .filter-bar input[type=text]:focus {
                    outline: none;
                    border-color: var(--teal);
                    background: #fff;
                }

        .btn-teal {
            background: var(--teal);
            color: #fff;
            border: none;
            border-radius: 6px;
            padding: .45rem 1rem;
            font-size: .875rem;
            font-weight: 500;
            cursor: pointer;
            transition: background .15s;
        }

            .btn-teal:hover {
                background: var(--teal-dark);
                color: #fff;
            }

        .sort-btn {
            background: none;
            border: 1px solid #ccdede;
            border-radius: 6px;
            padding: .4rem .75rem;
            font-size: .8rem;
            color: #4a6060;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: .3rem;
            transition: background .15s;
        }

            .sort-btn:hover {
                background: #eef4f4;
            }

        .pc-footer {
            text-align: right;
            padding: .75rem 1.75rem;
            font-size: .75rem;
            color: #aab;
        }

        .empty-state {
            text-align: center;
            padding: 3rem 1rem;
            color: #8a9999;
        }

            .empty-state svg {
                margin-bottom: .75rem;
                opacity: .4;
            }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sidebar-header">
            <div class="menu-label">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <line x1="3" y1="12" x2="21" y2="12" />
                    <line x1="3" y1="6" x2="21" y2="6" />
                    <line x1="3" y1="18" x2="21" y2="18" />
                </svg>
                Menu
            </div>
        </div>
        <nav class="sidebar-nav">
            <a asp-controller="Technician" asp-action="Dashboard"
               class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
                    <polyline points="9 22 9 12 15 12 15 22" />
                </svg>
                Dashboard
            </a>
            <a asp-controller="Technician" asp-action="ViewBookings"
               class="@(ViewContext.RouteData.Values["action"]?.ToString() == "ViewBookings" ? "active" : "")">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                    <line x1="16" y1="2" x2="16" y2="6" />
                    <line x1="8" y1="2" x2="8" y2="6" />
                    <line x1="3" y1="10" x2="21" y2="10" />
                </svg>
                View Bookings
            </a>
            <a asp-controller="Technician" asp-action="ViewCustomers"
               class="@(ViewContext.RouteData.Values["action"]?.ToString() == "ViewCustomers" ? "active" : "")">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" />
                    <circle cx="9" cy="7" r="4" />
                    <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" />
                </svg>
                View Customers
            </a>
        </nav>
        <div class="sidebar-footer">
            <a asp-controller="Account" asp-action="Logout">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9" />
                </svg>
                Logout
            </a>
        </div>
    </div>

    <!-- Topbar -->
    <div class="topbar">
        <h1>Technician</h1>
        <span class="brand">PC Society</span>
        <div class="user-icon">
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" />
                <circle cx="12" cy="7" r="4" />
            </svg>
        </div>
    </div>

    <!-- Main -->
    <div class="main-content">
        <div class="page-body">
            @RenderBody()
        </div>
        <div class="pc-footer">PC Society &copy; @DateTime.Now.Year</div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>