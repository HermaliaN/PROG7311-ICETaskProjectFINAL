@{
    ViewData["Title"] = "Technician Dashboard";
    Layout = "~/Views/Technician/_TechnicianLayout.cshtml";
}

<p class="mb-4" style="color:#4a6060; font-size:.925rem;">
    Welcome, <strong>@ViewBag.UserName</strong> — here's your Technician workspace.
</p>

<div class="row g-3">
    <!-- View Bookings card -->
    <div class="col-12 col-sm-6 col-md-4">
        <a asp-controller="Technician" asp-action="ViewBookings" class="text-decoration-none">
            <div class="pc-card p-4 text-center dashboard-card">
                <div class="dash-icon mb-3">
                    <svg width="40" height="40" fill="none" stroke="#4aada8" stroke-width="1.5" viewBox="0 0 24 24">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                        <line x1="16" y1="2" x2="16" y2="6" />
                        <line x1="8" y1="2" x2="8" y2="6" />
                        <line x1="3" y1="10" x2="21" y2="10" />
                    </svg>
                </div>
                <div style="font-weight:600; color:#1a2e2e; font-size:1rem;">Bookings</div>
            </div>
        </a>
    </div>

    <!-- View Customers card -->
    <div class="col-12 col-sm-6 col-md-4">
        <a asp-controller="Technician" asp-action="ViewCustomers" class="text-decoration-none">
            <div class="pc-card p-4 text-center dashboard-card">
                <div class="dash-icon mb-3">
                    <svg width="40" height="40" fill="none" stroke="#4aada8" stroke-width="1.5" viewBox="0 0 24 24">
                        <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" />
                        <circle cx="9" cy="7" r="4" />
                        <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" />
                    </svg>
                </div>
                <div style="font-weight:600; color:#1a2e2e; font-size:1rem;">View Customers</div>
            </div>
        </a>
    </div>
</div>

<p class="mt-3" style="color:#8a9999; font-size:.8rem;">
    Click bookings below to see what has been assigned to you
</p>

<style>
    .dashboard-card {
        transition: transform .15s, box-shadow .15s;
        cursor: pointer;
    }

    .dashboard-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 6px 20px rgba(74,173,168,.18);
    }

    .dash-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 80px;
        height: 80px;
        background: #d4eeec;
        border-radius: 14px;
        margin: 0 auto;
    }
</style>