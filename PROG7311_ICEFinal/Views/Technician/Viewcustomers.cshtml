@model IEnumerable<PROG7311_ICEFinal.Models.Customer>
@{
    ViewData["Title"] = "Customer Database";
    Layout = "~/Views/Technician/_TechnicianLayout.cshtml";
    var currentSort = ViewBag.CurrentSort as string;
    var nextSort = currentSort == "asc" ? "desc" : "asc";
}

<h1 class="page-title">Customer Database</h1>
<p class="page-subtitle">Search for customers to view their contact details</p>

<!-- Filter bar -->
<form method="get" asp-action="ViewCustomers">
    <div class="filter-bar">
        <div class="search-wrap">
            <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <circle cx="11" cy="11" r="8" />
                <line x1="21" y1="21" x2="16.65" y2="16.65" />
            </svg>
            <input type="text"
                   name="search"
                   value="@ViewBag.CurrentSearch"
                   placeholder="Search by name, email or phone..." />
        </div>
        <input type="hidden" name="sortOrder" value="@currentSort" />
        <button type="submit" class="btn-teal">Search</button>
        @if (!string.IsNullOrWhiteSpace(ViewBag.CurrentSearch as string))
        {
            <a asp-action="ViewCustomers" class="btn-teal" style="background:#6a8080; text-decoration:none;">Clear</a>
        }

        <!-- Sort toggle -->
        <a asp-action="ViewCustomers"
           asp-route-search="@ViewBag.CurrentSearch"
           asp-route-sortOrder="@nextSort"
           class="sort-btn ms-auto">
            Sort by
            @if (currentSort == "asc")
            {
                <span>Name</span>
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <polyline points="18 15 12 9 6 15" />
                </svg>
            }
            else
            {
                <span>Newest</span>
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <polyline points="6 9 12 15 18 9" />
                </svg>
            }
        </a>
    </div>
</form>

<div class="pc-card">
    @if (!Model.Any())
    {
        <div class="empty-state">
            <svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" />
                <circle cx="9" cy="7" r="4" />
                <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" />
            </svg>
            <p>No customers found.</p>
        </div>
    }
    else
    {
        <table class="pc-table">
            <thead>
                <tr>
                    <th>Customer ID</th>
                    <th>Customer Name</th>
                    <th>Phone Number</th>
                    <th>Customer Email</th>
                    <th>Order In Progress</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var customer in Model)
                {
                    <tr>
                        <td>#@customer.CustomerId</td>
                        <td>@customer.Name</td>
                        <td>@customer.PhoneNumber</td>
                        <td>
                            <a href="mailto:@customer.Email" style="color:#4aada8; text-decoration:none;">
                                @customer.Email
                            </a>
                        </td>
                        <td>
                            @{
                                var hasActiveBooking = customer.Bookings != null &&
                                customer.Bookings.Any(b => b.Status == "In Progress" || b.Status == "Pending");
                            }
                            @if (hasActiveBooking)
                            {
                                <span class="status-badge badge-inprogress">Yes</span>
                            }
                            else
                            {
                                <span class="status-badge badge-completed">No</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>