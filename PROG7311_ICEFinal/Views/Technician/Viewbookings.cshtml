@model IEnumerable<PROG7311_ICEFinal.Models.Booking>
@{
    ViewData["Title"] = "View Bookings";
    Layout = "~/Views/Technician/_TechnicianLayout.cshtml";
    var currentSort = ViewBag.CurrentSort as string;
    var nextSort = currentSort == "asc" ? "desc" : "asc";
}

<h1 class="page-title">Bookings</h1>
<p class="page-subtitle">View your allocated bookings</p>

<!-- Filter bar -->
<form method="get" asp-action="ViewBookings">
    <div class="filter-bar">
        <div class="search-wrap">
            <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <circle cx="11" cy="11" r="8" />
                <line x1="21" y1="21" x2="16.65" y2="16.65" />
            </svg>
            <input type="text"
                   name="search"
                   value="@ViewBag.CurrentSearch"
                   placeholder="Search by technician name..." />
        </div>
        <input type="hidden" name="sortOrder" value="@currentSort" />
        <button type="submit" class="btn-teal">Search</button>
        @if (!string.IsNullOrWhiteSpace(ViewBag.CurrentSearch as string))
        {
            <a asp-action="ViewBookings" class="btn-teal" style="background:#6a8080; text-decoration:none;">Clear</a>
        }

        <!-- Sort by date -->
        <a asp-action="ViewBookings"
           asp-route-search="@ViewBag.CurrentSearch"
           asp-route-sortOrder="@nextSort"
           class="sort-btn ms-auto">
            Sort by Date
            @if (currentSort == "asc")
            {
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <polyline points="18 15 12 9 6 15" />
                </svg>
            }
            else
            {
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <polyline points="6 9 12 15 18 9" />
                </svg>
            }
        </a>
    </div>
</form>

<div class="pc-card">
    @if (!Model.Any())
    {
        <div class="empty-state">
            <svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                <line x1="16" y1="2" x2="16" y2="6" />
                <line x1="8" y1="2" x2="8" y2="6" />
                <line x1="3" y1="10" x2="21" y2="10" />
            </svg>
            <p>No bookings found.</p>
        </div>
    }
    else
    {
        <table class="pc-table">
            <thead>
                <tr>
                    <th>Booking ID</th>
                    <th>Customer Name</th>
                    <th>Service</th>
                    <th>Booking Date</th>
                    <th>Technician</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var booking in Model)
                {
                    <tr>
                        <td>#@booking.BookingId</td>
                        <td>@(booking.Customer?.Name ?? "—")</td>
                        <td>@booking.ServiceType</td>
                        <td>@booking.BookingDate.ToString("dd MMM yyyy")</td>
                        <td>
                            @if (booking.Technician != null)
                            {
                                @(booking.Technician.FirstName + " " + booking.Technician.LastName)
                            }
                            else
                            {
                                <span style="color:#aab;">Unassigned</span>
                            }
                        </td>
                        <td>
                            @{
                                var statusClass = booking.Status switch
                                {
                                    "Pending" => "badge-pending",
                                    "In Progress" => "badge-inprogress",
                                    "Completed" => "badge-completed",
                                    "Cancelled" => "badge-cancelled",
                                    _ => "badge-pending"
                                };
                            }
                            <span class="status-badge @statusClass">@booking.Status</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
