@model PROG7311_ICEFinal.Models.LoginViewModel

@{
    Layout = null;
    ViewData["Title"] = "Login - PC Society";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PC Society Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background-color: #f4f4f2;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Jost', sans-serif;
        }

        .login-card {
            background: #ffffff;
            border-radius: 4px;
            padding: 52px 48px 48px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 2px 24px rgba(0, 0, 0, 0.06);
            animation: fadeUp 0.5s ease both;
        }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(16px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .logo-wrap {
            display: flex;
            justify-content: center;
            margin-bottom: 28px;
        }

            .logo-wrap img {
                width: 90px;
                height: auto;
            }

        .login-heading {
            text-align: center;
            margin-bottom: 6px;
        }

            .login-heading h1 {
                font-family: 'Cormorant Garamond', serif;
                font-weight: 400;
                font-size: 2rem;
                color: #1a1a1a;
                letter-spacing: 0.02em;
            }

            .login-heading p {
                font-size: 0.78rem;
                color: #888;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                margin-top: 4px;
            }

        .form-section {
            margin-top: 32px;
        }

        .field-group {
            margin-bottom: 20px;
        }

            .field-group label {
                display: block;
                font-size: 0.68rem;
                font-weight: 500;
                letter-spacing: 0.12em;
                text-transform: uppercase;
                color: #555;
                margin-bottom: 7px;
            }

            .field-group input {
                width: 100%;
                border: 1px solid #ddd;
                border-radius: 3px;
                padding: 10px 13px;
                font-size: 0.9rem;
                font-family: 'Jost', sans-serif;
                color: #1a1a1a;
                background: #fafafa;
                outline: none;
                transition: border-color 0.2s, box-shadow 0.2s;
            }

                .field-group input:focus {
                    border-color: #8bbcb5;
                    box-shadow: 0 0 0 3px rgba(139, 188, 181, 0.18);
                    background: #fff;
                }

            .field-group .text-danger {
                font-size: 0.75rem;
                margin-top: 4px;
                display: block;
            }

        .btn-login {
            width: 100%;
            padding: 11px;
            background-color: #8bbcb5;
            border: none;
            border-radius: 3px;
            color: #fff;
            font-family: 'Jost', sans-serif;
            font-size: 0.82rem;
            font-weight: 500;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            cursor: pointer;
            margin-top: 8px;
            transition: background-color 0.2s, transform 0.1s;
        }

            .btn-login:hover {
                background-color: #7aada5;
            }

            .btn-login:active {
                transform: scale(0.99);
            }

        .alert-danger {
            font-size: 0.83rem;
            padding: 10px 14px;
            border-radius: 3px;
            margin-bottom: 20px;
        }

        .demo-creds {
            margin-top: 28px;
            padding-top: 20px;
            border-top: 1px solid #eee;
            font-size: 0.72rem;
            color: #aaa;
            text-align: center;
            line-height: 1.9;
        }

            .demo-creds strong {
                color: #999;
                display: block;
                margin-bottom: 4px;
                letter-spacing: 0.06em;
            }
    </style>
</head>
<body>

    <div class="login-card">

        <div class="logo-wrap">
            <img src="~/images/logo.png" alt="PC Society Logo" />
        </div>

        <div class="login-heading">
            <h1>Login</h1>
            <p>Enter your credentials</p>
        </div>

        @if (!string.IsNullOrEmpty(ViewBag.Error))
        {
            <div class="alert alert-danger mt-3">
                @ViewBag.Error
            </div>
        }

        <div class="form-section">
            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()

                <div class="field-group">
                    <label asp-for="Username">Username</label>
                    <input asp-for="Username" placeholder="Your username" autocomplete="off" />
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>

                <div class="field-group">
                    <label asp-for="Password">Password</label>
                    <input asp-for="Password" type="password" placeholder="••••••" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <button type="submit" class="btn-login">Login</button>
            </form>
        </div>

        <div class="demo-creds">
            <strong>Demo Credentials</strong>
            <span class="badge bg-secondary">Admin</span> admin / admin123 &nbsp;
            <span class="badge bg-secondary">Tech</span> technician / tech123 &nbsp;
            <span class="badge bg-secondary">Sales</span> sales / sales123
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>